<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>영어단어 플래시카드</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;600;700;800&display=swap');

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Noto Sans KR', sans-serif;
            background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
            min-height: 100vh;
            color: #fff;
            overflow-x: hidden;
        }

        .app-header {
            text-align: center;
            padding: 30px 20px 10px;
        }

        .app-header h1 {
            font-size: 2rem;
            font-weight: 800;
            background: linear-gradient(90deg, #f7971e, #ffd200);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .app-header p {
            color: rgba(255,255,255,0.6);
            font-size: 0.9rem;
            margin-top: 5px;
        }

        .container {
            max-width: 700px;
            margin: 0 auto;
            padding: 20px;
        }

        /* ===== 입력 섹션 ===== */
        #input-section {
            background: rgba(255,255,255,0.07);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 30px;
            border: 1px solid rgba(255,255,255,0.1);
        }

        #input-section h2 {
            font-size: 1.2rem;
            margin-bottom: 8px;
            font-weight: 600;
        }

        .input-guide {
            color: rgba(255,255,255,0.55);
            font-size: 0.82rem;
            margin-bottom: 15px;
            line-height: 1.6;
        }

        .input-guide code {
            background: rgba(255,255,255,0.12);
            padding: 2px 7px;
            border-radius: 4px;
            font-family: monospace;
            font-size: 0.85rem;
        }

        textarea {
            width: 100%;
            height: 200px;
            border: 2px solid rgba(255,255,255,0.15);
            border-radius: 12px;
            background: rgba(0,0,0,0.3);
            color: #fff;
            padding: 15px;
            font-size: 0.95rem;
            font-family: 'Noto Sans KR', monospace;
            resize: vertical;
            transition: border-color 0.3s;
            line-height: 1.8;
        }

        textarea:focus {
            outline: none;
            border-color: #ffd200;
        }

        textarea::placeholder {
            color: rgba(255,255,255,0.3);
        }

        .btn-group {
            display: flex;
            gap: 10px;
            margin-top: 15px;
            flex-wrap: wrap;
        }

        .btn {
            padding: 12px 28px;
            border: none;
            border-radius: 12px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            font-family: 'Noto Sans KR', sans-serif;
        }

        .btn-primary {
            background: linear-gradient(135deg, #f7971e, #ffd200);
            color: #1a1a2e;
            flex: 1;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(255,210,0,0.3);
        }

        .btn-secondary {
            background: rgba(255,255,255,0.1);
            color: #fff;
            border: 1px solid rgba(255,255,255,0.2);
        }

        .btn-secondary:hover {
            background: rgba(255,255,255,0.2);
        }

        .btn-small {
            padding: 8px 16px;
            font-size: 0.85rem;
            border-radius: 8px;
        }

        /* ===== 게임 섹션 ===== */
        #game-section {
            display: none;
        }

        .game-topbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            flex-wrap: wrap;
            gap: 10px;
        }

        .progress-info {
            font-size: 0.95rem;
            color: rgba(255,255,255,0.8);
        }

        .progress-info span {
            color: #ffd200;
            font-weight: 700;
        }

        .progress-bar-container {
            width: 100%;
            height: 8px;
            background: rgba(255,255,255,0.1);
            border-radius: 10px;
            margin-bottom: 25px;
            overflow: hidden;
        }

        .progress-bar {
            height: 100%;
            background: linear-gradient(90deg, #f7971e, #ffd200);
            border-radius: 10px;
            transition: width 0.5s ease;
        }

        .scoreboard {
            display: flex;
            justify-content: center;
            gap: 30px;
            margin-bottom: 25px;
        }

        .score-item { text-align: center; }

        .score-item .score-num {
            font-size: 2rem;
            font-weight: 800;
        }

        .score-item .score-label {
            font-size: 0.75rem;
            color: rgba(255,255,255,0.5);
            margin-top: 2px;
        }

        .score-know .score-num { color: #4ade80; }
        .score-dontknow .score-num { color: #f87171; }
        .score-remain .score-num { color: #ffd200; }

        /* ===== 플래시카드 ===== */
        .card-area {
            perspective: 1000px;
            margin-bottom: 25px;
        }

        .flashcard {
            width: 100%;
            min-height: 280px;
            position: relative;
            cursor: pointer;
            transform-style: preserve-3d;
            transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .flashcard.flipped {
            transform: rotateY(180deg);
        }

        .card-face {
            position: absolute;
            width: 100%;
            min-height: 280px;
            backface-visibility: hidden;
            border-radius: 24px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 30px;
        }

        .card-front {
            background: linear-gradient(145deg, #1e1b4b, #312e81);
            border: 2px solid rgba(139, 92, 246, 0.3);
            box-shadow: 0 20px 60px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.1);
        }

        .card-back {
            background: linear-gradient(145deg, #1a3a2a, #064e3b);
            border: 2px solid rgba(52, 211, 153, 0.3);
            box-shadow: 0 20px 60px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.1);
            transform: rotateY(180deg);
        }

        .card-label {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 3px;
            color: rgba(255,255,255,0.4);
            margin-bottom: 15px;
        }

        .card-word {
            font-size: 2.8rem;
            font-weight: 800;
            letter-spacing: 1px;
            text-align: center;
            word-break: break-word;
        }

        .card-front .card-word {
            color: #c4b5fd;
        }

        .card-back .card-word {
            color: #6ee7b7;
            font-size: 2rem;
        }

        .card-hint {
            margin-top: 15px;
            font-size: 0.85rem;
            color: rgba(255,255,255,0.4);
        }

        .speaker-btn {
            margin-top: 15px;
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.2);
            color: #fff;
            width: 50px;
            height: 50px;
            border-radius: 50%;
            font-size: 1.4rem;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .speaker-btn:hover {
            background: rgba(255,255,255,0.2);
            transform: scale(1.1);
        }

        .speaker-btn.speaking {
            background: rgba(255,210,0,0.3);
            border-color: #ffd200;
        }

        /* 액션 버튼 */
        .action-buttons {
            display: flex;
            gap: 15px;
            justify-content: center;
        }

        .btn-know, .btn-dontknow {
            flex: 1;
            max-width: 200px;
            padding: 16px 20px;
            border: none;
            border-radius: 16px;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
            font-family: 'Noto Sans KR', sans-serif;
        }

        .btn-know {
            background: linear-gradient(135deg, #059669, #34d399);
            color: #fff;
        }

        .btn-know:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(52,211,153,0.3);
        }

        .btn-dontknow {
            background: linear-gradient(135deg, #dc2626, #f87171);
            color: #fff;
        }

        .btn-dontknow:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(248,113,113,0.3);
        }

        /* ===== 결과 섹션 ===== */
        #result-section {
            display: none;
            text-align: center;
        }

        .result-card {
            background: rgba(255,255,255,0.07);
            backdrop-filter: blur(10px);
            border-radius: 24px;
            padding: 40px 30px;
            border: 1px solid rgba(255,255,255,0.1);
        }

        .result-emoji { font-size: 4rem; margin-bottom: 15px; }

        .result-title {
            font-size: 1.8rem;
            font-weight: 800;
            margin-bottom: 10px;
        }

        .result-subtitle {
            color: rgba(255,255,255,0.6);
            margin-bottom: 25px;
        }

        .result-stats {
            display: flex;
            justify-content: center;
            gap: 40px;
            margin-bottom: 30px;
        }

        .result-stat { text-align: center; }

        .result-stat .stat-num {
            font-size: 2.5rem;
            font-weight: 800;
        }

        .result-stat .stat-label {
            font-size: 0.8rem;
            color: rgba(255,255,255,0.5);
        }

        .stat-correct .stat-num { color: #4ade80; }
        .stat-wrong .stat-num { color: #f87171; }

        .wrong-words-section {
            margin-top: 25px;
            text-align: left;
        }

        .wrong-words-section h3 {
            font-size: 1rem;
            color: #f87171;
            margin-bottom: 12px;
            text-align: center;
        }

        .wrong-word-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: rgba(248,113,113,0.1);
            border: 1px solid rgba(248,113,113,0.2);
            border-radius: 10px;
            padding: 12px 18px;
            margin-bottom: 8px;
            cursor: pointer;
            transition: background 0.2s;
        }

        .wrong-word-item:hover {
            background: rgba(248,113,113,0.2);
        }

        .wrong-word-en {
            font-weight: 700;
            color: #fca5a5;
            font-size: 1.05rem;
        }

        .wrong-word-ko {
            color: rgba(255,255,255,0.7);
            font-size: 0.9rem;
        }

        .result-buttons {
            display: flex;
            gap: 10px;
            margin-top: 25px;
            flex-wrap: wrap;
            justify-content: center;
        }

        .result-buttons .btn {
            flex: 1;
            min-width: 150px;
        }

        .btn-retry-wrong {
            background: linear-gradient(135deg, #dc2626, #f87171);
            color: #fff;
        }

        .btn-retry-wrong:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(248,113,113,0.3);
        }

        /* ===== 모드 선택 ===== */
        .mode-selector {
            display: flex;
            gap: 10px;
            margin-top: 15px;
            margin-bottom: 5px;
        }

        .mode-btn {
            flex: 1;
            padding: 10px;
            border: 2px solid rgba(255,255,255,0.15);
            border-radius: 10px;
            background: transparent;
            color: rgba(255,255,255,0.6);
            font-size: 0.85rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            font-family: 'Noto Sans KR', sans-serif;
        }

        .mode-btn.active {
            border-color: #ffd200;
            color: #ffd200;
            background: rgba(255,210,0,0.1);
        }

        .mode-btn:hover {
            border-color: rgba(255,255,255,0.4);
            color: rgba(255,255,255,0.9);
        }

        /* 설정 토글 */
        .settings-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-top: 12px;
            padding: 8px 0;
        }

        .settings-row label {
            font-size: 0.85rem;
            color: rgba(255,255,255,0.7);
        }

        .toggle {
            width: 44px;
            height: 24px;
            background: rgba(255,255,255,0.15);
            border-radius: 12px;
            position: relative;
            cursor: pointer;
            transition: background 0.3s;
        }

        .toggle.active {
            background: #f7971e;
        }

        .toggle::after {
            content: '';
            width: 18px;
            height: 18px;
            background: #fff;
            border-radius: 50%;
            position: absolute;
            top: 3px;
            left: 3px;
            transition: transform 0.3s;
        }

        .toggle.active::after {
            transform: translateX(20px);
        }

        .sample-btn {
            display: inline-block;
            margin-top: 8px;
            padding: 6px 14px;
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 8px;
            color: rgba(255,255,255,0.6);
            font-size: 0.8rem;
            cursor: pointer;
            transition: all 0.3s;
            font-family: 'Noto Sans KR', sans-serif;
        }

        .sample-btn:hover {
            background: rgba(255,255,255,0.15);
            color: #fff;
        }

        /* 타이핑 모드 */
        .typing-area {
            display: none;
            margin-bottom: 20px;
        }

        .typing-input-wrap {
            display: flex;
            gap: 10px;
        }

        .typing-input {
            flex: 1;
            padding: 14px 18px;
            border: 2px solid rgba(255,255,255,0.15);
            border-radius: 12px;
            background: rgba(0,0,0,0.3);
            color: #fff;
            font-size: 1.1rem;
            font-family: 'Noto Sans KR', sans-serif;
            text-align: center;
            transition: border-color 0.3s;
        }

        .typing-input:focus {
            outline: none;
            border-color: #ffd200;
        }

        .typing-input.correct {
            border-color: #4ade80;
            background: rgba(74, 222, 128, 0.1);
        }

        .typing-input.wrong {
            border-color: #f87171;
            background: rgba(248, 113, 113, 0.1);
        }

        .typing-submit-btn {
            padding: 14px 22px;
            border: none;
            border-radius: 12px;
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            color: #fff;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            font-family: 'Noto Sans KR', sans-serif;
            transition: all 0.3s;
            white-space: nowrap;
        }

        .typing-submit-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(99,102,241,0.4);
        }

        .typing-result {
            margin-top: 12px;
            font-size: 0.95rem;
            min-height: 24px;
            text-align: center;
        }

        .typing-hint-btn {
            margin-top: 8px;
            padding: 6px 16px;
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 8px;
            background: rgba(255,255,255,0.05);
            color: rgba(255,255,255,0.5);
            font-size: 0.8rem;
            cursor: pointer;
            font-family: 'Noto Sans KR', sans-serif;
            transition: all 0.3s;
        }

        .typing-hint-btn:hover {
            background: rgba(255,255,255,0.1);
            color: rgba(255,255,255,0.8);
        }

        /* TTS 상태 표시 */
        .tts-status {
            text-align: center;
            font-size: 0.75rem;
            color: rgba(255,255,255,0.35);
            margin-top: 5px;
        }

        .tts-status.ready { color: rgba(74, 222, 128, 0.6); }
        .tts-status.error { color: rgba(248, 113, 113, 0.6); }

        /* ===== 반응형 ===== */
        @media (max-width: 500px) {
            .app-header h1 { font-size: 1.5rem; }
            .card-word { font-size: 2rem; }
            .card-back .card-word { font-size: 1.5rem; }
            .card-face { min-height: 230px; padding: 25px 20px; }
            .flashcard { min-height: 230px; }
            .scoreboard { gap: 20px; }
            .score-item .score-num { font-size: 1.5rem; }
            .result-stats { gap: 25px; }
            .result-stat .stat-num { font-size: 2rem; }
            .typing-input-wrap { flex-direction: column; }
        }

        /* ===== 애니메이션 ===== */
        @keyframes slideUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .animate-in {
            animation: slideUp 0.5s ease forwards;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }

        .pulse {
            animation: pulse 0.3s ease;
        }
    </style>
</head>
<body>

<div class="app-header">
    <h1>📚 영어단어 플래시카드</h1>
    <p>단어를 입력하고 게임처럼 외워보자!</p>
</div>

<div class="container">

    <!-- ===== 입력 섹션 ===== -->
    <div id="input-section" class="animate-in">
        <h2>📝 단어 입력</h2>
        <div class="input-guide">
            한 줄에 하나씩, 영어단어와 뜻을 입력하세요.<br>
            형식: <code>영어단어 - 한국어뜻</code> 또는 <code>영어단어 : 한국어뜻</code> 또는 <code>영어단어, 한국어뜻</code>
        </div>
        <textarea id="word-input" placeholder="예시:&#10;accomplish - 성취하다, 달성하다&#10;generate : 발생시키다&#10;opportunity - 기회&#10;magnificent - 장엄한, 웅장한"></textarea>
        <button class="sample-btn" onclick="loadSample()">📋 예시 단어 불러오기</button>

        <div class="mode-selector">
            <button class="mode-btn active" data-mode="flashcard" onclick="selectMode('flashcard')">🃏 플래시카드</button>
            <button class="mode-btn" data-mode="typing" onclick="selectMode('typing')">⌨️ 타이핑 퀴즈</button>
        </div>

        <div class="settings-row">
            <label>🔊 자동 발음 재생</label>
            <div class="toggle active" id="auto-speak-toggle" onclick="toggleAutoSpeak()"></div>
        </div>
        <div class="tts-status" id="tts-status">🔄 음성 엔진 로딩 중...</div>

        <div class="btn-group">
            <button class="btn btn-primary" onclick="startGame()">🚀 학습 시작!</button>
        </div>
    </div>

    <!-- ===== 게임 섹션 ===== -->
    <div id="game-section">
        <div class="game-topbar">
            <div class="progress-info">
                <span id="current-num">1</span> / <span id="total-num">0</span>
            </div>
            <div>
                <button class="btn btn-secondary btn-small" onclick="goBack()">✏️ 단어 수정</button>
            </div>
        </div>

        <div class="progress-bar-container">
            <div class="progress-bar" id="progress-bar" style="width: 0%"></div>
        </div>

        <div class="scoreboard">
            <div class="score-item score-know">
                <div class="score-num" id="know-count">0</div>
                <div class="score-label">알고 있어요 ✅</div>
            </div>
            <div class="score-item score-dontknow">
                <div class="score-num" id="dontknow-count">0</div>
                <div class="score-label">모르겠어요 ❌</div>
            </div>
            <div class="score-item score-remain">
                <div class="score-num" id="remain-count">0</div>
                <div class="score-label">남은 단어</div>
            </div>
        </div>

        <!-- 카드 영역 -->
        <div class="card-area" id="card-area">
            <div class="flashcard" id="flashcard" onclick="flipCard()">
                <div class="card-face card-front">
                    <div class="card-label" id="front-label">ENGLISH</div>
                    <div class="card-word" id="card-front-word">word</div>
                    <button class="speaker-btn" id="front-speaker" onclick="event.stopPropagation(); speakWord()">🔊</button>
                    <div class="card-hint" id="front-hint">카드를 클릭하면 뜻을 볼 수 있어요</div>
                </div>
                <div class="card-face card-back">
                    <div class="card-label" id="back-label">한국어 뜻</div>
                    <div class="card-word" id="card-back-word">뜻</div>
                    <button class="speaker-btn" id="back-speaker" onclick="event.stopPropagation(); speakWord()" style="display:none;">🔊</button>
                </div>
            </div>
        </div>

        <!-- 타이핑 모드 입력 -->
        <div class="typing-area" id="typing-area">
            <div class="typing-input-wrap">
                <input type="text" class="typing-input" id="typing-input" placeholder="영어 단어를 입력하세요..." autocomplete="off" spellcheck="false">
                <button class="typing-submit-btn" onclick="checkTypingAnswer()">확인</button>
            </div>
            <div class="typing-result" id="typing-result"></div>
            <div style="text-align:center;">
                <button class="typing-hint-btn" id="typing-hint-btn" onclick="showTypingHint()">💡 힌트 보기 (첫 글자)</button>
            </div>
        </div>

        <!-- 플래시카드 모드 버튼 -->
        <div class="action-buttons" id="action-buttons">
            <button class="btn-dontknow" onclick="markWord(false)">❌ 모르겠어요</button>
            <button class="btn-know" onclick="markWord(true)">✅ 알고 있어요!</button>
        </div>
    </div>

    <!-- ===== 결과 섹션 ===== -->
    <div id="result-section">
        <div class="result-card animate-in">
            <div class="result-emoji" id="result-emoji">🎉</div>
            <div class="result-title" id="result-title">학습 완료!</div>
            <div class="result-subtitle" id="result-subtitle">잘 했어요!</div>

            <div class="result-stats">
                <div class="result-stat stat-correct">
                    <div class="stat-num" id="result-correct">0</div>
                    <div class="stat-label">맞은 단어</div>
                </div>
                <div class="result-stat stat-wrong">
                    <div class="stat-num" id="result-wrong">0</div>
                    <div class="stat-label">틀린 단어</div>
                </div>
            </div>

            <div class="wrong-words-section" id="wrong-words-section" style="display:none;">
                <h3>📌 다시 외울 단어</h3>
                <div id="wrong-words-list"></div>
            </div>

            <div class="result-buttons">
                <button class="btn btn-retry-wrong" id="btn-retry-wrong" onclick="retryWrong()" style="display:none;">
                    🔄 틀린 단어만 다시
                </button>
                <button class="btn btn-primary" onclick="retryAll()">🔁 전체 다시</button>
                <button class="btn btn-secondary" onclick="goBack()">✏️ 새 단어 입력</button>
            </div>
        </div>
    </div>

</div>

<script>
    // ===== 상태 변수 =====
    let allWords = [];
    let gameWords = [];
    let currentIndex = 0;
    let knowList = [];
    let dontKnowList = [];
    let isFlipped = false;
    let autoSpeak = true;
    let gameMode = 'flashcard';
    let typingAnswered = false;

    // ===== TTS (음성 합성) 관련 =====
    let ttsReady = false;
    let englishVoice = null;
    let voicesLoaded = false;

    // 영어 음성 찾기
    function findEnglishVoice() {
        if (!('speechSynthesis' in window)) {
            updateTTSStatus('❌ 이 브라우저는 음성을 지원하지 않습니다', 'error');
            return;
        }

        const voices = window.speechSynthesis.getVoices();
        if (voices.length === 0) return; // 아직 로딩 안됨

        voicesLoaded = true;

        // 영어 음성 우선순위로 찾기
        const priorities = [
            // 1순위: 미국 영어 고품질 음성
            v => v.lang === 'en-US' && v.name.includes('Google'),
            v => v.lang === 'en-US' && v.name.includes('Samantha'),
            v => v.lang === 'en-US' && v.name.includes('Alex'),
            v => v.lang === 'en-US' && v.name.includes('Natural'),
            v => v.lang === 'en-US' && v.name.includes('Enhanced'),
            // 2순위: 미국 영어 아무거나
            v => v.lang === 'en-US',
            // 3순위: 영국 영어
            v => v.lang === 'en-GB',
            // 4순위: 영어권 아무거나
            v => v.lang.startsWith('en-'),
            v => v.lang.startsWith('en'),
        ];

        for (const test of priorities) {
            const found = voices.find(test);
            if (found) {
                englishVoice = found;
                break;
            }
        }

        if (englishVoice) {
            ttsReady = true;
            updateTTSStatus(`✅ 음성 준비 완료 (${englishVoice.name})`, 'ready');
            console.log('TTS 영어 음성 선택:', englishVoice.name, englishVoice.lang);
        } else {
            // 영어 전용 음성을 못 찾았어도 기본 음성으로 시도 가능
            ttsReady = true;
            updateTTSStatus('✅ 음성 준비 완료 (기본 음성)', 'ready');
            console.log('전용 영어 음성 없음, 기본 음성 사용');
        }
    }

    function updateTTSStatus(text, className) {
        const el = document.getElementById('tts-status');
        if (el) {
            el.textContent = text;
            el.className = 'tts-status ' + (className || '');
        }
    }

    // 음성 목록 로딩 (비동기 처리)
    function initTTS() {
        if (!('speechSynthesis' in window)) {
            updateTTSStatus('❌ 이 브라우저는 음성을 지원하지 않습니다', 'error');
            return;
        }

        // 즉시 시도
        findEnglishVoice();

        // 비동기 로딩 이벤트
        window.speechSynthesis.onvoiceschanged = function() {
            findEnglishVoice();
        };

        // 안전장치: 일정 시간 후에도 안 되면 재시도
        setTimeout(() => {
            if (!voicesLoaded) {
                findEnglishVoice();
            }
        }, 500);

        setTimeout(() => {
            if (!voicesLoaded) {
                findEnglishVoice();
                if (!voicesLoaded) {
                    ttsReady = true; // 그래도 시도는 해봄
                    updateTTSStatus('⚠️ 음성 목록 로딩 지연 (발음은 작동할 수 있습니다)', 'ready');
                }
            }
        }, 2000);
    }

    // 발음 실행
    function speakWord(word) {
        const text = word || gameWords[currentIndex]?.en;
        if (!text) return;

        if (!('speechSynthesis' in window)) {
            console.warn('speechSynthesis 미지원');
            return;
        }

        // 기존 발음 중지
        window.speechSynthesis.cancel();

        // cancel 후 약간의 딜레이를 줘야 일부 브라우저에서 안정적
        setTimeout(() => {
            const utter = new SpeechSynthesisUtterance(text);
            utter.lang = 'en-US';
            utter.rate = 0.85;
            utter.pitch = 1;
            utter.volume = 1;

            // 영어 음성이 있으면 지정
            if (englishVoice) {
                utter.voice = englishVoice;
            }

            // 발음 시작/종료 시 버튼 시각 피드백
            utter.onstart = function() {
                document.querySelectorAll('.speaker-btn').forEach(btn => {
                    btn.classList.add('speaking');
                });
            };

            utter.onend = function() {
                document.querySelectorAll('.speaker-btn').forEach(btn => {
                    btn.classList.remove('speaking');
                });
            };

            utter.onerror = function(e) {
                console.warn('TTS 오류:', e.error);
                document.querySelectorAll('.speaker-btn').forEach(btn => {
                    btn.classList.remove('speaking');
                });
            };

            window.speechSynthesis.speak(utter);
        }, 50);
    }

    // 페이지 로드 시 TTS 초기화
    initTTS();

    // Chrome에서 speechSynthesis가 멈추는 버그 방지 (긴 세션 대응)
    setInterval(() => {
        if (window.speechSynthesis && window.speechSynthesis.speaking) {
            window.speechSynthesis.resume();
        }
    }, 10000);

    // ===== 샘플 단어 =====
    function loadSample() {
        document.getElementById('word-input').value =
`accomplish - 성취하다, 달성하다
generate - 발생시키다, 만들어내다
opportunity - 기회
magnificent - 장엄한, 웅장한
determine - 결정하다
essential - 필수적인, 본질적인
concentrate - 집중하다
frequently - 자주, 빈번하게
extraordinary - 비범한, 놀라운
persuade - 설득하다
sufficient - 충분한
consequences - 결과, 영향
demonstrate - 보여주다, 시연하다
enormous - 거대한, 막대한
hesitate - 망설이다, 주저하다`;
    }

    // ===== 모드 선택 =====
    function selectMode(mode) {
        gameMode = mode;
        document.querySelectorAll('.mode-btn').forEach(btn => {
            btn.classList.toggle('active', btn.dataset.mode === mode);
        });
    }

    // ===== 자동발음 토글 =====
    function toggleAutoSpeak() {
        autoSpeak = !autoSpeak;
        document.getElementById('auto-speak-toggle').classList.toggle('active', autoSpeak);
    }

    // ===== 단어 파싱 =====
    function parseWords(text) {
        const lines = text.trim().split('\n');
        const words = [];
        for (let line of lines) {
            line = line.trim();
            if (!line) continue;

            let parts = null;
            if (line.includes(' - ')) parts = line.split(' - ');
            else if (line.includes(' : ')) parts = line.split(' : ');
            else if (line.includes(' , ')) parts = line.split(' , ');
            else if (line.includes('-')) parts = line.split('-');
            else if (line.includes(':')) parts = line.split(':');
            else if (line.includes(',')) parts = line.split(',');

            if (parts && parts.length >= 2) {
                const en = parts[0].trim();
                const ko = parts.slice(1).join(',').trim();
                if (en && ko) {
                    words.push({ en, ko });
                }
            }
        }
        return words;
    }

    // ===== 셔플 =====
    function shuffle(arr) {
        const a = [...arr];
        for (let i = a.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [a[i], a[j]] = [a[j], a[i]];
        }
        return a;
    }

    // ===== 게임 시작 =====
    function startGame() {
        const text = document.getElementById('word-input').value;
        const parsed = parseWords(text);

        if (parsed.length === 0) {
            alert('단어를 올바른 형식으로 입력해주세요!\n예: apple - 사과');
            return;
        }

        allWords = parsed;
        beginRound(allWords);
    }

    function beginRound(words) {
        gameWords = shuffle(words);
        currentIndex = 0;
        knowList = [];
        dontKnowList = [];
        isFlipped = false;
        typingAnswered = false;

        document.getElementById('input-section').style.display = 'none';
        document.getElementById('result-section').style.display = 'none';
        document.getElementById('game-section').style.display = 'block';
        document.getElementById('game-section').classList.add('animate-in');

        document.getElementById('total-num').textContent = gameWords.length;

        // 모드에 따라 UI 전환
        const typingArea = document.getElementById('typing-area');
        const actionButtons = document.getElementById('action-buttons');
        const frontHint = document.getElementById('front-hint');

        if (gameMode === 'typing') {
            typingArea.style.display = 'block';
            actionButtons.style.display = 'none';
            frontHint.style.display = 'none';
        } else {
            typingArea.style.display = 'none';
            actionButtons.style.display = 'flex';
            frontHint.style.display = 'block';
        }

        showCard();
    }

    // ===== 카드 표시 =====
    function showCard() {
        if (currentIndex >= gameWords.length) {
            showResult();
            return;
        }

        const word = gameWords[currentIndex];
        const card = document.getElementById('flashcard');

        // 카드 초기화
        card.classList.remove('flipped');
        isFlipped = false;
        typingAnswered = false;

        if (gameMode === 'flashcard') {
            // 플래시카드 모드: 앞면=영어, 뒷면=한국어
            document.getElementById('front-label').textContent = 'ENGLISH';
            document.getElementById('card-front-word').textContent = word.en;
            document.getElementById('card-front-word').style.color = '#c4b5fd';
            document.getElementById('front-speaker').style.display = 'flex';
            document.getElementById('front-hint').textContent = '카드를 클릭하면 뜻을 볼 수 있어요';
            document.getElementById('front-hint').style.display = 'block';

            document.getElementById('back-label').textContent = '한국어 뜻';
            document.getElementById('card-back-word').textContent = word.ko;
            document.getElementById('back-speaker').style.display = 'none';
        } else {
            // 타이핑 모드: 앞면=한국어 뜻, 뒷면=영어 단어 (정답)
            document.getElementById('front-label').textContent = '한국어 뜻';
            document.getElementById('card-front-word').textContent = word.ko;
            document.getElementById('card-front-word').style.color = '#fbbf24';
            document.getElementById('front-speaker').style.display = 'none';
            document.getElementById('front-hint').style.display = 'none';

            document.getElementById('back-label').textContent = 'ANSWER';
            document.getElementById('card-back-word').textContent = word.en;
            document.getElementById('back-speaker').style.display = 'flex';
        }

        document.getElementById('current-num').textContent = currentIndex + 1;
        updateScoreboard();

        // 프로그레스바
        const progress = ((knowList.length + dontKnowList.length) / gameWords.length) * 100;
        document.getElementById('progress-bar').style.width = progress + '%';

        // 타이핑 모드 리셋
        if (gameMode === 'typing') {
            const input = document.getElementById('typing-input');
            input.value = '';
            input.className = 'typing-input';
            input.disabled = false;
            document.getElementById('typing-result').innerHTML = '';
            document.getElementById('typing-hint-btn').style.display = 'inline-block';
            setTimeout(() => input.focus(), 100);
        }

        // 플래시카드 모드에서 자동 발음
        if (gameMode === 'flashcard' && autoSpeak) {
            setTimeout(() => speakWord(word.en), 400);
        }

        // 애니메이션
        card.parentElement.classList.add('pulse');
        setTimeout(() => card.parentElement.classList.remove('pulse'), 300);
    }

    // ===== 스코어 업데이트 =====
    function updateScoreboard() {
        document.getElementById('know-count').textContent = knowList.length;
        document.getElementById('dontknow-count').textContent = dontKnowList.length;
        document.getElementById('remain-count').textContent = gameWords.length - knowList.length - dontKnowList.length;
    }

    // ===== 카드 뒤집기 =====
    function flipCard() {
        if (gameMode === 'typing' && !typingAnswered) return;
        const card = document.getElementById('flashcard');
        isFlipped = !isFlipped;
        card.classList.toggle('flipped', isFlipped);
    }

    // ===== 단어 체크 (플래시카드 모드) =====
    function markWord(known) {
        if (currentIndex >= gameWords.length) return;

        const word = gameWords[currentIndex];
        if (known) {
            knowList.push(word);
        } else {
            dontKnowList.push(word);
        }

        currentIndex++;
        showCard();
    }

    // ===== 타이핑 힌트 =====
    function showTypingHint() {
        const word = gameWords[currentIndex];
        if (!word) return;
        const hint = word.en[0] + '_'.repeat(word.en.length - 1);
        document.getElementById('typing-result').innerHTML =
            `<span style="color:#fbbf24;">💡 힌트: <strong>${hint}</strong> (${word.en.length}글자)</span>`;
        document.getElementById('typing-hint-btn').style.display = 'none';
    }

    // ===== 타이핑 정답 확인 =====
    function checkTypingAnswer() {
        if (typingAnswered) {
            currentIndex++;
            showCard();
            return;
        }

        const input = document.getElementById('typing-input');
        const resultDiv = document.getElementById('typing-result');
        const word = gameWords[currentIndex];
        if (!word) return;

        const userAnswer = input.value.trim().toLowerCase();
        if (!userAnswer) {
            input.focus();
            return;
        }

        const correctAnswer = word.en.toLowerCase().trim();
        const isCorrect = (userAnswer === correctAnswer);

        input.disabled = true;
        typingAnswered = true;

        if (isCorrect) {
            input.classList.add('correct');
            resultDiv.innerHTML = `<span style="color:#4ade80">⭕ 정답! <strong>${word.en}</strong></span>`;
            if (autoSpeak) speakWord(word.en);
            knowList.push(word);
            setTimeout(() => {
                currentIndex++;
                showCard();
            }, 1200);
        } else {
            input.classList.add('wrong');
            resultDiv.innerHTML = `<span style="color:#f87171">❌ 오답! 정답: <strong>${word.en}</strong></span>`;
            if (autoSpeak) speakWord(word.en);
            document.getElementById('flashcard').classList.add('flipped');
            isFlipped = true;
            dontKnowList.push(word);
            setTimeout(() => {
                currentIndex++;
                showCard();
            }, 2500);
        }

        document.getElementById('typing-hint-btn').style.display = 'none';
    }

    // ===== 타이핑 Enter 키 =====
    document.addEventListener('keydown', function(e) {
        if (gameMode !== 'typing') return;
        if (document.getElementById('game-section').style.display === 'none') return;

        if (e.key === 'Enter') {
            e.preventDefault();
            checkTypingAnswer();
        }
    });

    // ===== 결과 표시 =====
    function showResult() {
        document.getElementById('game-section').style.display = 'none';
        document.getElementById('result-section').style.display = 'block';

        const total = gameWords.length;
        const correct = knowList.length;
        const wrong = dontKnowList.length;
        const percent = Math.round((correct / total) * 100);

        document.getElementById('result-correct').textContent = correct;
        document.getElementById('result-wrong').textContent = wrong;

        let emoji, title, subtitle;
        if (percent === 100) {
            emoji = '🏆'; title = '완벽해요!'; subtitle = '모든 단어를 다 알고 있어요! 천재!';
        } else if (percent >= 80) {
            emoji = '🎉'; title = '훌륭해요!'; subtitle = `${percent}% 정답! 거의 다 외웠어요!`;
        } else if (percent >= 60) {
            emoji = '💪'; title = '잘하고 있어요!'; subtitle = `${percent}% 정답! 조금만 더 힘내요!`;
        } else if (percent >= 40) {
            emoji = '📖'; title = '더 노력해봐요!'; subtitle = `${percent}% 정답! 틀린 단어를 다시 외워보세요!`;
        } else {
            emoji = '🔥'; title = '화이팅!'; subtitle = `${percent}% 정답! 다시 도전해봐요!`;
        }

        document.getElementById('result-emoji').textContent = emoji;
        document.getElementById('result-title').textContent = title;
        document.getElementById('result-subtitle').textContent = subtitle;

        // 틀린 단어 목록
        const wrongSection = document.getElementById('wrong-words-section');
        const wrongListEl = document.getElementById('wrong-words-list');
        const retryBtn = document.getElementById('btn-retry-wrong');

        if (wrong > 0) {
            wrongSection.style.display = 'block';
            retryBtn.style.display = 'inline-block';
            wrongListEl.innerHTML = '';
            for (let w of dontKnowList) {
                const item = document.createElement('div');
                item.className = 'wrong-word-item';
                item.innerHTML = `
                    <span class="wrong-word-en">${w.en}</span>
                    <span class="wrong-word-ko">${w.ko}</span>
                `;
                item.onclick = () => speakWord(w.en);
                wrongListEl.appendChild(item);
            }
        } else {
            wrongSection.style.display = 'none';
            retryBtn.style.display = 'none';
        }
    }

    // ===== 재시도 =====
    function retryWrong() {
        beginRound(dontKnowList);
    }

    function retryAll() {
        beginRound(allWords);
    }

    function goBack() {
        document.getElementById('game-section').style.display = 'none';
        document.getElementById('result-section').style.display = 'none';
        document.getElementById('input-section').style.display = 'block';
    }

    // ===== 키보드 단축키 (플래시카드 모드) =====
    document.addEventListener('keydown', function(e) {
        if (gameMode !== 'flashcard') return;
        if (document.getElementById('game-section').style.display === 'none') return;

        if (e.key === ' ' || e.key === 'ArrowUp' || e.key === 'ArrowDown') {
            e.preventDefault();
            flipCard();
        } else if (e.key === 'ArrowRight' || e.key === 'o' || e.key === 'O') {
            markWord(true);
        } else if (e.key === 'ArrowLeft' || e.key === 'x' || e.key === 'X') {
            markWord(false);
        }
    });
</script>

</body>
</html>
